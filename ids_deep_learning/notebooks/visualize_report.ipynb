   "source": [
    "# NIDS Experimental Report Visualization Notebook\n",
    "\n",
    "This notebook contains static performance data from `experimental_report.md` and generates high-resolution, publication-quality visualizations for the evaluation of the **Multi-Dataset Hybrid NIDS Framework**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "\n",
    "# Set premium aesthetic settings\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "plt.rcParams.update({\n",
    "    'font.size': 11,\n",
    "    'axes.labelsize': 12,\n",
    "    'axes.titlesize': 14,\n",
    "    'xtick.labelsize': 10,\n",
    "    'ytick.labelsize': 10,\n",
    "    'figure.titlesize': 16\n",
    "})\n",
    "\n",
    "# Ensure plot directory exists\n",
    "Path(\"../results/plots\").mkdir(parents=True, exist_ok=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---  \n",
    "## 1. Imbalance Handling Benchmark (CICIDS2017)\n",
    "\n",
    "This section visualizes the trade-off between **Macro-F1** and **False Alarm Rate (FAR)** when employing different class imbalance strategies on the 10% fraction of the CICIDS2017 dataset."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "C:\\Users\\Admin\\AppData\\Local\\Temp\\ipykernel_2084\\1990951830.py:26: UserWarning: set_ticklabels() should only be used with a fixed number of ticks, i.e. after set_ticks() or using a FixedLocator.\n",
      "  ax1.set_xticklabels(ax1.get_xticklabels(), rotation=15, ha='right')\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x600 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "imbalance_data = {\n",
    "    \"Scenario\": [\n",
    "        \"MLP_FocalSampler\",\n",
    "        \"MLP_SamplerOnly\",\n",
    "        \"MLP_FocalOnly (gamma=2)\",\n",
    "        \"MLP_FocalOnly (gamma=1)\",\n",
    "        \"MLP_FocalOnly (gamma=0.5)\",\n",
    "        \"MLP_CE_ClassWeight\",\n",
    "    ],\n",
    "    \"Accuracy\": [0.6753, 0.5489, 0.7512, 0.8690, 0.8512, 0.9412],\n",
    "    \"Macro-F1\": [0.3395, 0.3262, 0.3934, 0.4491, 0.4972, 0.5890],\n",
    "    \"Weighted-F1\": [0.7436, 0.5892, 0.8123, 0.8988, 0.8872, 0.9512],\n",
    "    \"FAR\": [0.3856, 0.4900, 0.2732, 0.1312, 0.1634, 0.0590],\n",
    "}\n",
    "\n",
    "df_imbalance = pd.DataFrame(imbalance_data)\n",
    "\n",
    "fig, ax1 = plt.subplots(figsize=(12, 6))\n",
    "\n",
    "# Plot Macro-F1\n",
    "color = '#1f77b4'\n",
    "ax1.set_xlabel('Imbalance Handling Strategy', fontweight='bold', labelpad=12)\n",
    "ax1.set_ylabel('Macro-F1 Score', color=color, fontweight='bold')\n",
    "sns.barplot(x='Scenario', y='Macro-F1', data=df_imbalance, ax=ax1, palette='Blues_r', hue='Scenario', legend=False)\n",
    "ax1.tick_params(axis='y', labelcolor=color)\n",
    "ax1.set_xticklabels(ax1.get_xticklabels(), rotation=15, ha='right')\n",
    "ax1.set_ylim(0, 1.0)\n",
    "\n",
    "# Create twin axis for FAR\n",
    "ax2 = ax1.twinx()\n",
    "color = '#d62728'\n",
    "ax2.set_ylabel('False Alarm Rate (FAR)', color=color, fontweight='bold')\n",
    "sns.lineplot(x=df_imbalance['Scenario'], y=df_imbalance['FAR'], ax=ax2, color=color, marker='o', linewidth=2.5, sort=False)\n",
    "ax2.tick_params(axis='y', labelcolor=color)\n",
    "ax2.set_ylim(0, 0.6)\n",
    "\n",
    "plt.title('CICIDS2017: Imbalance Handling Strategy Trade-off (Macro-F1 vs FAR)', fontsize=14, fontweight='bold', pad=15)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../results/plots/cicids2017_imbalance_tradeoff.png', dpi=300)\n",
    "plt.show()"
   ]
  },
  {
